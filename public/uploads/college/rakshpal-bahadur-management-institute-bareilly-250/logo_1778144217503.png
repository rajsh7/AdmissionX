<!-- ════ SCRIPTS ════ -->
<script>
  const hamburger    = document.getElementById('hamburger');
  const megaMenu     = document.getElementById('megaMenu');
  const searchToggle = document.getElementById('searchToggle');
  const searchBar    = document.getElementById('searchBar');
  const headerWrap   = document.getElementById('headerWrap');

  function updateMenuTop() {
    megaMenu.style.top = headerWrap.getBoundingClientRect().bottom + 'px';
  }

  hamburger.addEventListener('click', () => {
    const open = megaMenu.classList.toggle('open');
    hamburger.classList.toggle('open', open);
    hamburger.setAttribute('aria-expanded', open);
    document.body.style.overflow = open ? 'hidden' : '';
    if (open) updateMenuTop();
  });

  window.addEventListener('resize', () => {
    if (megaMenu.classList.contains('open')) updateMenuTop();
  });

  searchToggle.addEventListener('click', () => {
    searchBar.classList.toggle('open');
    if (searchBar.classList.contains('open')) {
      searchBar.querySelector('input').focus();
      if (megaMenu.classList.contains('open')) updateMenuTop();
    }
  });

  document.querySelectorAll('[data-acc]').forEach(b => {
    b.querySelector('.cat-header').addEventListener('click', () => b.classList.toggle('expanded'));
  });

  document.querySelectorAll('[data-ls]').forEach(s => {
    s.querySelector('.ls-header').addEventListener('click', () => s.classList.toggle('expanded'));
  });

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') {
      megaMenu.classList.remove('open');
      hamburger.classList.remove('open');
      hamburger.setAttribute('aria-expanded', false);
      document.body.style.overflow = '';
    }
  });
</script>


