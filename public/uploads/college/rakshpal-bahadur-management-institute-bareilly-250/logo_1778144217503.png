        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
          <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
        </svg>
        Explore Courses
      </a>
    </div>

    <!-- Quick links -->
    <div class="err-links-label">Or visit a popular page</div>
    <div class="err-pills">
      <a href="/admissions"           class="err-pill">Admissions</a>
      <!--<a href="/bareilly-campus"      class="err-pill">Bareilly Campus</a>
      <a href="/greater-noida-campus" class="err-pill">Greater Noida Campus</a>-->
      <a href="/placement-cell"       class="err-pill">Placements</a>
      <!--<a href="/about-us"             class="err-pill">About RBMI</a>-->
      <a href="/contact-us"           class="err-pill">Contact Us</a>
    </div>

  </div>
</section>

<style>
/* ════ FOOTER ════ */
.ft-banner { background: #c8202f; padding: 28px 5% 32px; position: relative; }
.your-last-section { border-radius: 0 0 40px 40px; }
.ft-banner::after { display: none; }
.ft-banner-inner { max-width: 1320px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px; position: relative; z-index: 1; }
.ft-banner-text { font-family: 'Poppins', sans-serif; font-size: clamp(1rem, 2.2vw, 1.5rem); font-weight: 300; color: rgba(255,255,255,0.92); margin: 0; }
.ft-banner-text strong { font-weight: 700; color: #fff; }
.ft-banner-btns { display: flex; gap: 8px; flex-wrap: wrap; }
.ft-banner-btn { display: inline-flex; align-items: center; gap: 7px; background: transparent; border: 1px solid rgba(255,255,255,0.5); color: #fff; padding: 9px 20px; border-radius: 50px; text-decoration: none; font-family: 'Poppins', sans-serif; font-size: 12.5px; font-weight: 500; white-space: nowrap; transition: background 0.2s, border-color 0.2s; cursor: pointer; }
.ft-banner-btn:hover { background: rgba(255,255,255,0.12); border-color: rgba(255,255,255,0.8); }
.ft-banner-btn svg { width: 13px; height: 13px; flex-shrink: 0; }

/* ── Brochure Dropdown ── */
.ft-brochure-wrap { position: relative; }

/* ✅ FIX: dropdown starts at 100% (no gap in position),
   then uses padding-top to create the visual spacing.
   This way the hover area is continuous — no dead zone. */
.ft-brochure-dropdown {
  display: none;
  flex-direction: column;
  position: absolute;
  top: 100%;             /* flush — no gap in hover area */
  left: 0;
  min-width: 210px;
  background: #1a1a2e;
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 12px;
  overflow: hidden;
  z-index: 100;
  box-shadow: 0 8px 24px rgba(0,0,0,0.35);
  padding-top: 10px;     /* ✅ visual gap lives INSIDE the element */
}

/* ✅ Invisible bridge pseudo-element fills the gap above */
.ft-brochure-dropdown::before {
  content: '';
  position: absolute;
  top: -10px;
  left: 0;
  right: 0;
  height: 10px;
  background: transparent;
}

.ft-brochure-wrap:hover .ft-brochure-dropdown,
.ft-brochure-wrap:focus-within .ft-brochure-dropdown { display: flex; }

.ft-brochure-dropdown-label {
  padding: 2px 16px 6px;
  font-family: 'Poppins', sans-serif;
  font-size: 10px;
  font-weight: 600;
  color: rgba(255,255,255,0.3);
  letter-spacing: 0.12em;
  text-transform: uppercase;
}
.ft-brochure-dropdown a {
  display: flex;
  align-items: center;
  gap: 9px;
  padding: 10px 16px;
  font-family: 'Poppins', sans-serif;
  font-size: 12.5px;
  font-weight: 500;
  color: rgba(255,255,255,0.75);
  text-decoration: none;
  transition: background 0.2s, color 0.2s;
  border-top: 1px solid rgba(255,255,255,0.06);
}
.ft-brochure-dropdown a:hover { background: rgba(255,255,255,0.08); color: #fff; }
.ft-brochure-dropdown a svg { width: 13px; height: 13px; flex-shrink: 0; color: #4db3e8; }

.ft-main { background: #0a1628; padding: 52px 5% 0; }
.ft-main-inner { max-width: 1320px; margin: 0 auto; }
.ft-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 48px; padding-bottom: 48px; border-bottom: 1px solid rgba(255,255,255,0.06); }

.ft-left { display: flex; flex-direction: column; gap: 26px; }
.ft-logo-row { display: flex; align-items: center; gap: 20px; }
.ft-logo { height: 52px; width: auto; }
.ft-sep { width: 1px; height: 56px; background: rgba(255,255,255,0.18); flex-shrink: 0; }
.ft-years-wrap { display: flex; align-items: baseline; gap: 10px; }
.ft-years-num { font-family: 'Poppins', sans-serif; font-size: 2.6rem; font-weight: 300; color: #fff; line-height: 1; }
.ft-years-label { font-family: 'Poppins', sans-serif; font-size: 10px; font-weight: 500; color: rgba(255,255,255,0.55); text-transform: uppercase; letter-spacing: 0.15em; line-height: 1.6; }
.ft-addr-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
.ft-campus-name { font-family: 'Poppins', sans-serif; font-size: 13px; font-weight: 600; color: #fff; margin: 0 0 5px; }
.ft-campus-addr { font-family: 'Poppins', sans-serif; font-size: 12px; color: rgba(255,255,255,0.42); line-height: 1.85; margin: 0 0 12px; }
.ft-contact-link { display: flex; align-items: center; gap: 8px; text-decoration: none; margin-bottom: 7px; }
.ft-contact-link svg { width: 14px; height: 14px; color: #4db3e8; flex-shrink: 0; }
.ft-contact-link span { font-family: 'Poppins', sans-serif; font-size: 12px; color: rgba(255,255,255,0.55); transition: color 0.2s; }
.ft-contact-link:hover span { color: #fff; }
.ft-social { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
.ft-social-label { font-family: 'Poppins', sans-serif; font-size: 13px; font-weight: 600; color: #4db3e8; margin-right: 4px; }
.ft-social-btn { width: 38px; height: 38px; border-radius: 50%; border: 1.5px solid rgba(255,255,255,0.28); background: transparent; display: flex; align-items: center; justify-content: center; text-decoration: none; transition: border-color 0.2s, background 0.2s, transform 0.2s; }
.ft-social-btn:hover { border-color: rgba(255,255,255,0.7); background: rgba(255,255,255,0.06); transform: translateY(-2px); }
.ft-social-btn svg { width: 16px; height: 16px; fill: rgba(255,255,255,0.75); }

.ft-col { display: flex; flex-direction: column; }
.ft-col-heading { font-family: 'Poppins', sans-serif; font-size: 14px; font-weight: 500; color: #4db3e8; margin: 0 0 14px; }
.ft-col-heading.second { margin-top: 28px; }
.ft-col-link { font-family: 'Poppins', sans-serif; font-size: 13px; font-weight: 300; color: rgba(255,255,255,0.6); text-decoration: none; padding: 3.5px 0; line-height: 1.8; transition: color 0.2s; }
.ft-col-link:hover { color: #fff; }

/* ── Brochure sub-links inside ft-col ── */
.ft-col-brochure-group { display: flex; flex-direction: column; padding-left: 10px; border-left: 1.5px solid rgba(77,179,232,0.25); margin: 2px 0 2px; }
.ft-col-brochure-group .ft-col-link { font-size: 12px; color: rgba(255,255,255,0.45); padding: 2px 0; }
.ft-col-brochure-group .ft-col-link:hover { color: #fff; }

/* ── Bottom Bar ── */
.ft-bottom { background: #0a1628; padding: 16px 5%; border-top: 1px solid rgba(255,255,255,0.05); }
.ft-bottom-inner { max-width: 1320px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 10px; }
.ft-copy { font-family: 'Poppins', sans-serif; font-size: 12px; font-weight: 500; color: #4db3e8; letter-spacing: 0.08em; text-transform: uppercase; }
.ft-rights { font-family: 'Poppins', sans-serif; font-size: 12px; font-weight: 300; color: rgba(255,255,255,0.3); letter-spacing: 0; text-transform: none; }

/* ── Designer Credit ── */
.ft-designer { display: flex; align-items: center; gap: 7px; text-decoration: none; padding: 6px 14px; border: 1px solid rgba(255,255,255,0.1); border-radius: 50px; transition: border-color 0.2s, background 0.2s; }
.ft-designer:hover { border-color: rgba(255,255,255,0.3); background: rgba(255,255,255,0.04); }
.ft-designer-label { font-family: 'Poppins', sans-serif; font-size: 11px; font-weight: 300; color: rgba(255,255,255,0.35); letter-spacing: 0.04em; }
.ft-designer-name { font-family: 'Poppins', sans-serif; font-size: 11px; font-weight: 600; color: rgba(255,255,255,0.65); letter-spacing: 0.04em; transition: color 0.2s; }
.ft-designer:hover .ft-designer-name { color: #fff; }
.ft-designer-dot { width: 4px; height: 4px; border-radius: 50%; background: rgba(255,255,255,0.2); flex-shrink: 0; }

/* ── Responsive ── */
@media (max-width: 1024px) {
  .ft-grid { grid-template-columns: 1fr 1fr; gap: 32px; }
  .ft-left { grid-column: 1 / -1; }
}
@media (max-width: 640px) {
  .ft-grid { grid-template-columns: 1fr 1fr; gap: 24px; }
  .ft-left { grid-column: 1 / -1; }
  .ft-addr-cols { grid-template-columns: 1fr; }
  .ft-banner-inner { flex-direction: column; }
  .ft-bottom-inner { flex-direction: column; align-items: flex-start; gap: 10px; }
  .ft-brochure-dropdown { left: 0; min-width: 190px; }
}
</style>

