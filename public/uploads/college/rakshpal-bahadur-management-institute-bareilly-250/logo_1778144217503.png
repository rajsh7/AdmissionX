<!-- ════ SIDE PANEL SCRIPT ════ -->
<script>
  function toggleSideMenu() {
    var panel   = document.getElementById('rbmiSidePanel');
    var overlay = document.querySelector('.rbmi-side-overlay');
    var isOpen  = panel.classList.toggle('active');
    overlay.classList.toggle('active');
    document.body.style.overflow = isOpen ? 'hidden' : '';
  }
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      var panel = document.getElementById('rbmiSidePanel');
      if (panel.classList.contains('active')) toggleSideMenu();
    }
  });
</script>


<!-- ════ POPUP SCRIPT ════ -->
<script>
  (function () {
    const POPUP_KEY     = 'rbmi_popup_closed_at';
    const BLOCK_MINUTES = 3;
    const BLOCK_MS      = BLOCK_MINUTES * 60 * 1000;

    const overlay = document.getElementById('popupOverlay');
    const modal   = document.getElementById('admissionPopup');
    const closeBtn= document.getElementById('popupClose');

    function openPopup() {
      overlay.classList.add('show');
      modal.style.display = 'block';
      requestAnimationFrame(() => { requestAnimationFrame(() => modal.classList.add('show')); });
      document.body.style.overflow = 'hidden';
    }

    function closePopup() {
      modal.classList.remove('show');
      overlay.classList.remove('show');
      document.body.style.overflow = '';
      localStorage.setItem(POPUP_KEY, Date.now().toString());
      setTimeout(() => { modal.style.display = 'none'; }, 350);
    }

    function shouldShow() {
      const closed = localStorage.getItem(POPUP_KEY);
      if (!closed) return true;
      return (Date.now() - parseInt(closed, 10)) > BLOCK_MS;
    }

    if (shouldShow()) { setTimeout(openPopup, 1500); }

    closeBtn.addEventListener('click', closePopup);
    overlay.addEventListener('click', closePopup);
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape' && modal.classList.contains('show')) closePopup();
    });
  })();
</script>

<!-- ════ 404 PAGE — uses gs_style.css classes ════ -->
<style>
  .err-wrap {
    background: var(--navy);
    background-image: url(https://rbmi.in/image/66aca13f24279ac628932ef1RBMI-bg.svg);
    background-size: 160%;
    background-position: center;
    min-height: 78vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 60px 5%;
    position: relative;
    overflow: hidden;
  }
  .err-wrap::before {
    content: '404';
    position: absolute;
    font-family: 'Poppins', sans-serif;
    font-size: clamp(160px, 28vw, 300px);
    font-weight: 900;
    color: rgba(255,255,255,0.03);
    left: 50%; top: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    letter-spacing: -10px;
  }
  .err-wrap::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(13,27,62,0.55) 0%, transparent 70%);
    pointer-events: none;
  }
  .err-inner {
    max-width: 640px;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  /* big number */
  .err-code {
    font-family: 'Poppins', sans-serif;
    font-size: clamp(72px, 14vw, 120px);
    font-weight: 900;
    line-height: 1;
    margin-bottom: 6px;
    background: linear-gradient(135deg, var(--red) 0%, var(--gold) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: errPulse 3s ease-in-out infinite;
  }
  @keyframes errPulse {
    0%,100% { opacity:1; transform:scale(1); }
    50%      { opacity:.85; transform:scale(.98); }
  }

  .err-rule {
    width: 52px; height: 3px;
    background: linear-gradient(90deg, var(--red), var(--gold));
    border-radius: 3px;
    margin: 0 auto 22px;
  }

  .err-title {
    font-family: 'Poppins', sans-serif;
    font-size: clamp(20px,4vw,28px);
    font-weight: 700;
    color: #fff;
    margin: 0 0 10px;
    line-height: 1.3;
  }
  .err-sub {
    font-family: 'Open Sans', sans-serif;
    font-size: 15px;
    color: rgba(255,255,255,.55);
    line-height: 1.75;
    margin: 0 0 32px;
  }

  /* CTA buttons — reuse site button patterns */
  .err-btns { display:flex; gap:12px; justify-content:center; flex-wrap:wrap; margin-bottom:40px; }

  .err-btn-primary {
    display: inline-flex; align-items: center; gap: 8px;
    background: linear-gradient(135deg, var(--red) 0%, var(--red-dark) 100%);
    color: #fff;
    font-family: 'Poppins', sans-serif; font-size: 14px; font-weight: 600;
    padding: 12px 28px; border-radius: 50px; text-decoration: none;
    box-shadow: 0 6px 20px rgba(200,32,47,0.4);
    transition: transform .2s, box-shadow .2s;
  }
  .err-btn-primary:hover { transform: translateY(-2px); box-shadow: 0 10px 28px rgba(200,32,47,.55); }

  .err-btn-ghost {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(255,255,255,.08);
    color: rgba(255,255,255,.85);
    font-family: 'Poppins', sans-serif; font-size: 14px; font-weight: 600;
    padding: 12px 28px; border-radius: 50px; text-decoration: none;
    border: 1px solid rgba(255,255,255,.18);
    transition: background .2s, border-color .2s;
  }
  .err-btn-ghost:hover { background: rgba(255,255,255,.14); border-color: rgba(255,255,255,.35); }

  /* Quick links label — matches gs-section-title style */
  .err-links-label {
    font-family: 'Poppins', sans-serif;
    font-size: 10.5px; font-weight: 700;
    color: rgba(255,255,255,.3);
    text-transform: uppercase; letter-spacing: 1px;
    margin-bottom: 14px;
  }

  /* Pills — reuse tagline-badge feel */
  .err-pills { display:flex; flex-wrap:wrap; gap:8px; justify-content:center; }
  .err-pill {
    font-family: 'Poppins', sans-serif; font-size: 12.5px; font-weight: 500;
    color: rgba(255,255,255,.55); text-decoration: none;
    background: rgba(255,255,255,.06);
    border: 1px solid rgba(255,255,255,.1);
    padding: 6px 16px; border-radius: 20px;
    transition: background .2s, color .2s, border-color .2s;
  }
  .err-pill:hover {
    background: rgba(200,32,47,.15);
    color: #fca5a5;
    border-color: rgba(200,32,47,.35);
  }

  /* Floating dots */
  .err-dot { position:absolute; border-radius:50%; opacity:.1; pointer-events:none; animation:floatDot 6s ease-in-out infinite; }
  .err-dot-1 { width:80px;height:80px;background:var(--red);   top:14%;left:9%;  animation-delay:0s; }
  .err-dot-2 { width:40px;height:40px;background:var(--gold);  top:72%;left:7%;  animation-delay:1s; }
  .err-dot-3 { width:56px;height:56px;background:var(--rbmi-blue);top:18%;right:8%;animation-delay:2s;}
  .err-dot-4 { width:22px;height:22px;background:var(--gold);  top:76%;right:11%;animation-delay:.5s;}
  @keyframes floatDot { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-18px)} }

  @media(max-width:480px){
    .err-btns { flex-direction:column; align-items:center; }
    .err-btn-primary,.err-btn-ghost { width:100%; justify-content:center; }
    .err-dot { display:none; }
  }
</style>

<section class="err-wrap">

  <span class="err-dot err-dot-1"></span>
  <span class="err-dot err-dot-2"></span>
  <span class="err-dot err-dot-3"></span>
  <span class="err-dot err-dot-4"></span>

  <div class="err-inner">

    <!-- eyebrow — matches gs-hero-eyebrow pattern -->
    <p class="gs-hero-eyebrow" style="justify-content:center;color:rgba(255,255,255,.5);margin-bottom:4px;">
      RBMI Group of Institutions
    </p>

    <div class="err-code">404</div>
