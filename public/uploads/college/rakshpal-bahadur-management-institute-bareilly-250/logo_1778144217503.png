  <style>
  /* ════════════════════════════════════
     MEGA MENU — REDESIGNED 2-ROW LAYOUT
  ════════════════════════════════════ */

  /* Override old 6-col grid */
  .mm-grid { display: block; }

  /* TOP ROW — 3 columns */
  .mm-grid-top {
    display: grid;
    grid-template-columns: 1.15fr 1.15fr 1fr;
    gap: 0;
    border-bottom: 1px solid rgba(255,255,255,0.07);
    padding-bottom: 24px;
    margin-bottom: 0;
  }

  /* Campus columns spacing */
  .mm-grid-top .campus-col { padding: 0 28px; border-right: 1px solid rgba(255,255,255,0.07); }
  .mm-grid-top .campus-col:first-child { padding-left: 0; }
  .mm-grid-top .links-col { padding: 0 0 0 28px; border-right: none; }

  /* BOTTOM ROW — address + connect */
  .mm-bottom-row {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 0;
    padding-top: 20px;
    align-items: start;
  }
  .mm-bottom-row .loc-col { padding: 0 28px; border-right: 1px solid rgba(255,255,255,0.07); }
  .mm-bottom-row .connect-col { padding: 0 0 0 28px; }

  /* Campus title — improved pill style */
  .campus-title {
    font-size: 13px !important;
    font-weight: 700 !important;
    letter-spacing: 0.3px;
    margin-bottom: 18px !important;
    padding: 9px 16px !important;
    border-radius: 10px !important;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  /* Connect section — improved layout */
  .connect-col .connect-title {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.9px;
    color: rgba(255,255,255,0.4);
    margin-bottom: 12px;
    padding-bottom: 0;
    border-bottom: none;
  }
  .connect-col .social-row { gap: 8px; margin-bottom: 14px; }
  .connect-col .social-btn { width: 36px; height: 36px; border-radius: 8px; }
  .connect-col .footer-brand img { height: 32px; margin-top: 12px; }
  .connect-col .tagline-badges { margin-top: 10px; }

  /* loc-tag redesign */
  .loc-tag {
    font-size: 10.5px !important;
    font-weight: 700 !important;
    letter-spacing: 0.6px !important;
    text-transform: uppercase !important;
    margin-bottom: 8px !important;
    padding: 4px 10px !important;
    border-radius: 6px !important;
  }
  .loc-detail { font-size: 11.5px !important; line-height: 1.85 !important; }

  /* mm-footer tweaks */
  .mm-footer { margin-top: 20px !important; padding-top: 16px !important; }

  /* mm-inner breathing room */
  .mm-inner { padding: 28px 32px 24px !important; }

  /* Quick links col — inline standalones */
  .links-col .standalone-group {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-top: 4px;
  }
  .links-col .standalone {
    font-size: 12.5px;
    padding: 5px 10px;
  }

  /* Admission + About — side by side */
  .links-col .ls-2col-wrap {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0 16px;
    margin-bottom: 4px;
  }
  .links-col .ls-2col-wrap .link-section { margin-bottom: 0; }

  /* ── RESPONSIVE ── */
  @media (max-width: 960px) {
    .mm-grid-top { grid-template-columns: 1fr; }
    .mm-grid-top .campus-col,
    .mm-grid-top .links-col { padding: 0 0 20px; border-right: none; border-bottom: 1px solid rgba(255,255,255,0.07); }
    .mm-bottom-row { grid-template-columns: 1fr; gap: 16px; padding-top: 16px; }
    .mm-bottom-row .loc-col,
    .mm-bottom-row .connect-col { padding: 0; border-right: none; }
  }

  /* ── Bareilly UG courses — 2-column grid ── */
  .ug-2col {
    display: grid !important;
    grid-template-columns: 1fr 1fr;
    gap: 0 10px;
    padding: 4px 10px 8px;
  }
  .ug-2col .mm-link {
    font-size: 12px;
    padding: 3px 0;
  }
