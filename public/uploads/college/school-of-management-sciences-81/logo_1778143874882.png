<script type="text/javascript" src="https://smslucknow.ac.in/assets/js/app.js"></script>
<script type="text/javascript">

    let allWithoutDropdownMenu = document.querySelectorAll('ul .nav-item a');
    for(let menu of allWithoutDropdownMenu) {
        if (menu.getAttribute('data-item')) {
            if (menu.getAttribute('data-item').includes('home') && document.URL.includes('home')) {
                menu.classList.add('active');
            } else if (menu.getAttribute('data-item').includes('home') && window.location.pathname == '/') {
                menu.classList.add('active');
            } else if (menu.getAttribute('data-item').includes('contact') && document.URL.includes('contact')) {
                menu.classList.add('active');
            } else if (menu.getAttribute('data-item').includes('naac') && document.URL.includes('naac')) {
                menu.classList.add('active');
            }  else if (menu.getAttribute('data-item').includes('blog') && document.URL.includes('blog')) {
                menu.classList.add('active');
            }
        }
    }

    function searchMenu(elem)
    {
        let arr         = [];
        const lists     = document.querySelectorAll('.search-list li');
        let searchValue = elem.value.toLowerCase();
        if (searchValue == '' || searchValue == null) {
            console.log(searchValue);
            $(".search-list li").hide();
        }
        for (let list of lists) {
            let matchValue = list.innerText.toLowerCase();
            if (searchValue == null || searchValue == '') {
                list.style.display = 'none';
            } else {
                if (matchValue.includes(searchValue)) {
                    list.style.display = 'block';
                    if(list.querySelector('a')) {
                        list.querySelector('a').setAttribute('target', '_blank');
                    }
                    $(".search-list").css('padding','20px');
                } else {
                    list.style.display = 'none';
                }

                arr.push(list.style.display);
            }
        }

        if (!arr.includes('block')) {
            $(".search-list").append(`<li><a>Not found</a></li>`);
        }
    }

    /*Menu Search Js*/

     $(function(){

        $(".search-list li").hide();
        $(".search-list").css('padding','0px');
        /*Scroll menu Without ID*/
        if(!window.location.pathname.includes('uploads')) {
             
                
            // let slug = window.location.pathname.replaceAll('/','');
           
            // if(window.location.pathname.split("/").filter(item => item).length >= 2) {
            //     slug = window.location.pathname.replace('/','');
            // }
            // if (window.location.pathname.includes('profile')) {
            //     history.pushState({}, null, window.location.origin + '/' + slug);
            //     }
            
            // if(!window.location.href.includes('blog-details')) {
            //     history.pushState({}, null,window.location.origin +'/'+slug);
            // }
            // let showSection = document.getElementById(slug);
            // if (showSection) {
            //     scrollToTargetAdjusted(slug);
            // }

            var slug = window.location.pathname.replaceAll('/','');
 
    if (window.location.href.includes('profile') && (!$("section").hasClass("profilEPage"))) {
      var slug = window.location.pathname.replaceAll('/profile/', '');
      history.pushState({}, null, window.location.origin + '/' + slug);
      window.location=slug;
    }
    if (window.location.href.includes('blog-details') && (!$("section").hasClass("Details"))) {
      var slug = window.location.pathname.replaceAll('/blog-details/', '');
      history.pushState({}, null, window.location.origin + '/' + slug);
      window.location=slug;
    }
    
    if (window.location.href.includes('public') && !window.location.href.includes('publication')) {
      var slug = window.location.pathname.replaceAll('/public/', '');
      history.pushState({}, null, window.location.origin + '/' + slug);
      window.location=slug;

    }
    var showSection = document.getElementById(slug);
    if (showSection) {
      scrollToTargetAdjusted(slug);
    }
        }

        function scrollToTargetAdjusted(id){
            var element         = document.getElementById(id);
            var headerOffset    = 180;
            var elementPosition = element.getBoundingClientRect().top;
            var offsetPosition  = elementPosition + window.pageYOffset - headerOffset;
          
            window.scrollTo({
                 top: offsetPosition
            });
        }
    });

    // Redirect URL
  document.addEventListener('DOMContentLoaded',() => {
        let path = window.location.pathname;
        if(path == '/index.php' || path == '/publicindex.php' || path == '/public/index.php' || path == '/public/' || path == '/home') {
            history.pushState({}, null,window.location.origin);
        }
    })
    $('#submit').click(function() {
        $('#submit').addClass('header-admission-enquiry')

    })

</script>
</body>
</html>
