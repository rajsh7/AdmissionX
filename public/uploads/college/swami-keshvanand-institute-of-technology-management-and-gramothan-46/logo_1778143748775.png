if(jQuery("#name").val()!=""  && jQuery("#domicile_state").val()!="" && jQuery("#b_tech").val()!="" && jQuery("#course").val()!="" && jQuery("#qualification").val()!="" && jQuery("#contactno").val()=="" && jQuery("#email").val()=="")
