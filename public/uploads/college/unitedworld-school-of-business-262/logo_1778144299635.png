<script type="69b36544da69e154864b0a03-text/javascript">
document.addEventListener("DOMContentLoaded", function () {

  const dropdown = document.getElementById("programme_name");
  const hiddenField = document.querySelector("[name='program_full_name']");

  const programFullNameMap = {
    "Design": "B.Design (Hons.) Fashion Design & Technology",
    "Management": "BBA (Hons.) | 4 years",
    "Technology": "B. Tech-CSE | 4 years",
    "Law": "Integrated BBA LLB (Hons.) | 5 years",
    "Behavioural Sciences": "BSc - Psychology (Hons In Counselling Psychotherapy) with Industry Certification | 4 years",
    "Communication & Advertising": "BA (Hons) - Mass Communication | 4 years",
    "Research": "Ph.D"
  };

  //  Set default value (fallback if dropdown not ready yet)
  if (hiddenField) {
    hiddenField.value = "B.Design (Hons.) Fashion Design & Technology";
  }

  //  If dropdown exists (non-popup case), sync immediately
  if (dropdown && hiddenField) {
    hiddenField.value = programFullNameMap[dropdown.value] || hiddenField.value;
  }

});


//  Your existing working logic (for popup + dynamic change)
document.addEventListener("change", function (e) {

  if (e.target && e.target.id === "programme_name") {

    const selectedValue = e.target.value;
    const hiddenField = document.querySelector("[name='program_full_name']");

    const programFullNameMap = {
      "Design": "B.Design (Hons.) Fashion Design & Technology",
      "Management": "BBA (Hons.) | 4 years",
      "Technology": "B. Tech-CSE | 4 years",
      "Law": "Integrated BBA LLB (Hons.) | 5 years",
      "Behavioural Sciences": "BSc - Psychology (Hons In Counselling Psychotherapy) with Industry Certification | 4 years",
      "Communication & Advertising": "BA (Hons) - Mass Communication | 4 years",
      "Research": "Ph.D"
    };

    if (hiddenField) {
      hiddenField.value = programFullNameMap[selectedValue] || selectedValue;
    }
  }

});
</script>
