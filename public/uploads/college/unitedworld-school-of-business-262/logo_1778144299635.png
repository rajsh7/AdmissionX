    body {
  font-family: Arial, sans-serif;
  background: #f5f6f8;
}

.form-wrapper {
  text-align: center;
  padding: 0px 0px;
}

.form-header h2 {
  font-weight: 500;
  margin-bottom: 30px;
}

.form-card {
  background: #fff;
  max-width: 420px;
  margin: auto;
  padding: 0px;
  border-radius: 20px;
  box-shadow: none !important;
}

/* STEPPER */
.stepper {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 25px;
}

.step {
  width: 35px;
  height: 35px;
  border-radius: 50%;
  background: #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
}

.step.active {
  background: #cc1d1a;
  color: #fff;
}

.line {
  width: 60px;
  height: 2px;
  background: #ddd;
}

/* FORM */
.form-step {
  display: none;
  text-align: left;
}

.form-step.active {
  display: block;
}

label {
  display: block;
  margin: 10px 0 5px;
  font-size: 14px;
}

select {
  width: 100%;
  padding: 10px;
  border: 1px solid #ccc;
  border-radius: 10px;
}

.primary-btn {
  width: 100%;
  margin-top: 20px;
  padding: 12px;
  background: #cc1d1a;
  color: #fff;
  border: none;
  border-radius: 10px;
  cursor: pointer;
}

.primary-btn:hover {
  background: #cc1d1a;
}

.back-btn {
  background: none;
  border:none;
  color: #cc1d1a;
  margin-bottom: 10px;
  cursor: pointer;
  padding: 0px !important;
}

.back-btn:hover {
  background: none;
  border:none;
  color: #cc1d1a;
  margin-bottom: 10px;
  cursor: pointer;
  padding: 0px !important;
}

.hidden-fields-container{
    display: none;
}

.cf7-wrapper {
  padding: 0px 0px;
  background: transparent !important;
  border-radius: 12px;
  margin: auto;
  width: 100%;
  box-shadow: none !important;
}

.cf7-title {
  text-align: center;
  margin-bottom: 30px;
  font-weight: 700;
  color: #222;
  font-size: 26px;
}

.cf7-row {
  display: flex;
  flex-direction: column;
  align-items: left;
  margin-bottom: 20px;
  flex-wrap: wrap;
}

.cf7-label {
  width: 100%;
  font-weight: 600;
  color: #333;
  font-family: "Polymath", Sans-Serif;
  padding-bottom: 5px;
}

.cf7-field {
  width: 100%;
  padding-bottom: 10px;
  
}

.cf7-input {
  width: 100%;
  padding: 12px 15px;
  border-radius: 10px !important;
  border: 1px solid #ccc;
  outline: none;
  font-size: 16px !important;
}

.cf7-submit-wrap {
  text-align: center;
  margin-top: 20px;
}

.wpcf7-submit {
  background-color: #cc1d1a;
  color: #fff;
  padding: 12px 30px;
  border: none;
  border-radius: 10px !important;
  font-weight: 500 !important;
  font-size: 16px;
  cursor: pointer;
}

.wpcf7-submit:hover {
  background-color: #a31513;
}

.required {
  color: red;
}

/* Mobile */
@media (max-width: 600px) {
  .cf7-label,
  .cf7-field {
    width: 100%;
  }

  .cf7-label {
    margin-bottom: 6px;
  }
}
</style>



