<script type="69b36544da69e154864b0a03-text/javascript">
(function () {

  let selectedProgramme = "";

  // =========================
  // ✅ EVENT DELEGATION (KEY FIX)
  // =========================

  document.addEventListener("click", function (e) {

    // NEXT BUTTON
    if (e.target && e.target.id === "nextBtn") {

      const popup = e.target.closest('.elementor-popup-modal') || document;

      const step1 = popup.querySelector("#step-1");
      const formDesign = popup.querySelector("#form-design");
      const formOther = popup.querySelector("#form-other");

      const stepIndicator1 = popup.querySelector("#step-indicator-1");
      const stepIndicator2 = popup.querySelector("#step-indicator-2");

      const select = popup.querySelector("#programme_select");

      if (!select || !step1) return;

      selectedProgramme = select.value;

      if (!selectedProgramme) {
        alert("Please select a programme");
        return;
      }

      step1.classList.remove("active");
      stepIndicator1.classList.remove("active");
      stepIndicator2.classList.add("active");

      if (selectedProgramme === "B.Design (Hons.) Fashion Design & Technology") {
        formDesign.classList.add("active");
      } else {
        formOther.classList.add("active");
      }

      // SET HIDDEN FIELDS
      popup.querySelectorAll('input[name="val_programme_select"]').forEach(el => {
        el.value = selectedProgramme;
      });

      const source   = sessionStorage.getItem('utm_source') || 'NA';
      const medium   = sessionStorage.getItem('utm_medium') || 'NA';
      const campaign = sessionStorage.getItem('utm_campaign') || 'NA';

      popup.querySelectorAll('input[name="utm_source"]').forEach(el => el.value = source);
      popup.querySelectorAll('input[name="utm_medium"]').forEach(el => el.value = medium);
      popup.querySelectorAll('input[name="utm_campaign"]').forEach(el => el.value = campaign);
    }

    // BACK BUTTON
    if (e.target && e.target.classList.contains("back-btn")) {

      const popup = e.target.closest('.elementor-popup-modal') || document;

      const step1 = popup.querySelector("#step-1");
      const formDesign = popup.querySelector("#form-design");
      const formOther = popup.querySelector("#form-other");

      const stepIndicator1 = popup.querySelector("#step-indicator-1");
      const stepIndicator2 = popup.querySelector("#step-indicator-2");

      formDesign.classList.remove("active");
      formOther.classList.remove("active");

      step1.classList.add("active");

      stepIndicator2.classList.remove("active");
      stepIndicator1.classList.add("active");
    }

  });

  // =========================
  // CHANGE EVENT
  // =========================
  document.addEventListener("change", function (e) {

    if (e.target && e.target.id === "programme_select") {

      const popup = e.target.closest('.elementor-popup-modal') || document;

      popup.querySelectorAll('input[name="val_programme_select"]').forEach(el => {
        el.value = e.target.value;
      });

    }

  });

})();
</script>				</div>
				</div>
					</div>
				</div>
