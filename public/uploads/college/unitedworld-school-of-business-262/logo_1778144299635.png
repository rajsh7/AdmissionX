      <div class="form-group your-phone"><input class="wpcf7-form-control wpcf7-tel wpcf7-validates-as-required wpcf7-text wpcf7-validates-as-tel cf7-input form-control" id="your-phone" name="your-phone" type="tel" value="" placeholder="Enter your phone" aria-invalid="false" aria-required="true" required></div>
    </div>
  </div>

  
  <!-- Email -->
  <div class="cf7-row">
    <div class="cf7-label">
      Email <span class="required">*</span>
    </div>
    <div class="cf7-field">
      <div class="form-group your-email"><input class="wpcf7-form-control wpcf7-email wpcf7-validates-as-required wpcf7-text wpcf7-validates-as-email cf7-input form-control" id="your-email" name="your-email" type="email" value="" placeholder="Enter your email" aria-invalid="false" aria-required="true" required></div>
    </div>
  </div>


  <!-- Button -->
