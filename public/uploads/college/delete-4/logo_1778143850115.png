<style type="text/css">
.mySwiper {
	width: 100%;
	height: 700px;
	position: relative;
}
/* Image full cover */
.mySwiper img, .swiper-slide img {
	width: 100%;
	height: 100%;
	object-fit: cover;
}
/* Caption overlay center */
.slide-caption {
	position: absolute;
	inset: 0; /* top:0 left:0 right:0 bottom:0 */
	display: flex;
	flex-direction: column;
	justify-content: center;
	align-items: center;
	text-align: center;
	padding: 0 15px;
	color: #fff;

	z-index: 10;
}

/* Optional overlay dark layer for readability */
.swiper-slide::before {
 content: "";
 position: absolute;
 inset: 0;
 background: rgba(0, 0, 0, 0.35);
 z-index: 1;
}
.swiper-slide img {
	position: relative;
	z-index: 0;
}
/* Caption above overlay */
.slide-caption {
	z-index: 2;
}
.slide-caption h2 {
	color: #fff;
	font-size: 2.5em;
	font-weight: 700;
	text-transform: uppercase;
	margin-bottom: 10px;
}
.slide-caption p {
	font-size: 18px;
	max-width: 650px;
	margin-bottom: 20px;
	line-height: 1.4;
}
.slide-caption .btn, .slide-caption .blg-btn {
	display: inline-block;
	padding: 12px 30px;
	border-radius: 5px;
	font-weight: 500;
	text-decoration: none;
	transition: all 0.3s ease;
}
/* Buttons */
.slide-caption .btn {
	background: linear-gradient(90deg, #ffd94c, #ffcd02);
	color: #000;
}
.slide-caption .blg-btn {
	background: linear-gradient(90deg, #ff654c, #ff2602);
	color: #fff;
}
/* Hover */
.slide-caption .btn:hover, .slide-caption .blg-btn:hover {
	transform: translateY(-2px);
	box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
}
/* Blog button = Admission Open button size + 15px niche */
.slide-caption .blg-btn {
	padding: 12px 30px;     /* same as Admission Open */
	font-size: 16px;        /* same feel */
	margin-top: 15px;       /* 15px niche shift */
}

/* =========================
   esponsive Height Fix
========================= */
@media (max-width: 1024px) {
 .mySwiper {
height: 520px;
}
 .slide-caption h2 {
font-size: 28px;
}
 .slide-caption p {
font-size: 16px;
max-width: 100%;
}
 .slide-caption .btn,  .slide-caption .blg-btn {
padding: 10px 25px;
font-size: 14px;
}
}
 @media (max-width: 768px) {
 .mySwiper {
height: 420px;
}  /* fixed slider height for mobile */
 .slide-caption h2 {
font-size: 12px;
line-height: 1.2;
}
 .slide-caption p {
font-size: 7px;
margin-bottom: 12px;
}
 .slide-caption .btn,  .slide-caption .blg-btn {
padding: 10px 18px;
font-size: 13px;
}
}
 @media (max-width: 480px) {
 .mySwiper {
height: 360px;
}
 .slide-caption h2 {
font-size: 11px;
}
 .slide-caption p {
font-size: 6px;
}
}
/*obile slider height small */
@media (max-width: 768px) {
 .mySwiper {
 height: 280px;   /* yaha 280px / 320px try kar sakte ho */
}
 .swiper-slide img {
 height: 100%;
 object-fit: cover;  /* Revolution jaisa look */
}
}
@media (max-width: 480px) {
 .mySwiper {
 height: 260px;
}
}
/*obile par arrows + dots hide */
@media (max-width: 768px) {
 .swiper-button-next,  .swiper-button-prev,  .swiper-pagination {
 display: none !important;
}
}
.item-instructor {
	display: flex;
	align-items: center;
	padding: 15px;
	min-height: 120px; /* desktop ke liye */
}
.instructor-avatar img {
	max-width: 120px;
	height: auto;
}
.info-box {
	flex: 1;
	padding-left: 15px;
}
.info-box h3 {
	font-size: 15px;
	line-height: 1.4;
	margin: 0;
}
@media (max-width: 768px) {
 .item-instructor {
 flex-direction: column;
 text-align: center;
 min-height: auto;
}
 .info-box {
 padding-left: 0;
}
 .info-box h3 {
 font-size: 14px;
}
}
.news-img {
    width: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
}
.course-img {
    width: 100%;
    aspect-ratio: 1/1;
    object-fit: cover;
}
</style>
