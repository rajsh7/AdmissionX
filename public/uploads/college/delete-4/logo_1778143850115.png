    if (event.persisted) {
        console.log("Page restored from BFCache");
        // Yaha aap data refresh ya UI update kar sakte ho
    }
    // Example timer
    interval = setInterval(() => {
        console.log("Running...");
    }, 2000);
});

// Page cache hone se pehle cleanup
window.addEventListener("pagehide", function () {
