import pool from "@/lib/db";
import { unstable_cache } from "next/cache";
import type { Metadata } from "next";
import { RowDataPacket } from "mysql2";
import { Suspense } from "react";
import SearchClient from "@/app/search/SearchClient";
import type { CollegeResult } from "@/app/api/search/colleges/route";

// ── Dynamic page ─────────────────────────────────────────────────────────────
// This page reads searchParams (stream, degree, city_id, etc) which makes it
// inherently dynamic — do NOT set `export const revalidate` here because that
// would try to statically cache a page that also needs dynamic URL params,
// causing a Next.js deadlock where the server never sends a response.
// Data-layer caching is handled by unstable_cache inside getFilterData() and
// getCachedTopUniversities() below (10-min and 5-min TTLs respectively).
export const dynamic = "force-dynamic";

// ─── Types ────────────────────────────────────────────────────────────────────

interface FilterOption {
  id: string | number;
  name: string;
  slug?: string;
  count?: number;
}

interface CollegeRow extends RowDataPacket {
  id: number;
  slug: string;
  name: string;
  location: string | null;
  city_name: string | null;
  state_id: number | null;
  image: string | null;
  rating: string | null;
  totalRatingUser: string | null;
  ranking: string | null;
  isTopUniversity: number;
  topUniversityRank: string | null;
  universityType: string | null;
  estyear: string | null;
  verified: number;
  totalStudent: string | null;
  streams_raw: string | null;
  min_fees: string | null;
  max_fees: string | null;
}

interface IdRow extends RowDataPacket {
  id: number;
}

interface StreamRow extends RowDataPacket {
  id: number;
  name: string;
  pageslug: string | null;
  college_count: number;
}

interface DegreeRow extends RowDataPacket {
  id: number;
  name: string;
  pageslug: string | null;
}

interface CityRow extends RowDataPacket {
  id: number;
  name: string;
}

interface CountRow extends RowDataPacket {
  total: number;
}

// ─── Helpers ──────────────────────────────────────────────────────────────────

const IMAGE_BASE = "https://admin.admissionx.in/uploads/";
const DEFAULT_IMAGE =
  "https://images.unsplash.com/photo-1562774053-701939374585?auto=format&fit=crop&q=80&w=600";

function buildImageUrl(raw: string | null): string {
  if (!raw) return DEFAULT_IMAGE;
  if (raw.startsWith("http")) return raw;
  return `${IMAGE_BASE}${raw}`;
}

function slugToName(slug: string): string {
  return slug
    .replace(/-\d+$/, "")
    .split("-")
    .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
    .join(" ");
}

function buildColleges(rows: CollegeRow[]): CollegeResult[] {
  return rows.map((row) => {
    const name =
      row.name && row.name !== row.slug
        ? row.name
        : slugToName(row.slug || "university");

    const streams = row.streams_raw
      ? row.streams_raw
          .split("|")
          .map((s) => s.trim())
          .filter(Boolean)
      : [];

    return {
      id: row.id,
      slug: row.slug,
      name,
      location: row.location || row.city_name || "India",
      city_name: row.city_name,
      state_id: row.state_id,
      image: buildImageUrl(row.image),
      rating: parseFloat(String(row.rating)) || 0,
      totalRatingUser: parseInt(String(row.totalRatingUser)) || 0,
      ranking: row.ranking ? parseInt(String(row.ranking)) : null,
      isTopUniversity: row.isTopUniversity ?? 0,
      topUniversityRank: row.topUniversityRank
        ? parseInt(String(row.topUniversityRank))
        : null,
      universityType: row.universityType || null,
      estyear: row.estyear || null,
      verified: row.verified ?? 0,
      totalStudent: row.totalStudent
        ? parseInt(String(row.totalStudent))
        : null,
      streams,
      min_fees: row.min_fees ? parseInt(String(row.min_fees)) : null,
      max_fees: row.max_fees ? parseInt(String(row.max_fees)) : null,
    };
  });
}

// ─── Cached filter data ────────────────────────────────────────────────────────
//
// WHY THE OLD QUERY TIMED OUT:
//   The streams query did a 3-table JOIN:
//     functionalarea → collegemaster (66 k rows) → collegeprofile (isTopUniversity=1)
//   with COUNT(DISTINCT collegeprofile_id) + GROUP BY across the full fan-out.
//   MySQL couldn't use the composite index efficiently when the third table had
//   1 528 matching rows, causing a full nested-loop scan that exceeded 30 s.
//
// NEW APPROACH — 3-step application-layer query:
//
//   Step 1  Get all top-university IDs in one indexed scan (~105 ms).
//
//   Step 2  Use those literal IDs in two parallel queries:
//     a) collegemaster WHERE collegeprofile_id IN (literals)
//        GROUP BY functionalarea_id — MySQL uses idx_cm_profile_fa
//        (collegeprofile_id, functionalarea_id) for a near-instant scan.
//     b) city INNER JOIN collegeprofile WHERE id IN (literals)
//        — tiny result, uses the PRIMARY KEY.
//
//   Step 3  Look up functionalarea names for the top-N fa IDs.
//
//   Total: ~150 ms on first hit, then cached for 10 minutes.
// ─────────────────────────────────────────────────────────────────────────────

const getFilterData = async () => {
    try {
      // ── Step 1: get all top-university IDs + degrees in parallel ─────────
      const [[topIdRows], [degreeRows]] = await Promise.all([
        pool.query(
          "SELECT id FROM collegeprofile WHERE isTopUniversity = 1",
        ) as Promise<[{ id: number }[], unknown]>,

        pool.query(
          `SELECT d.id, d.name, d.pageslug
           FROM degree d
           WHERE d.name IS NOT NULL AND d.name != '' AND d.isShowOnTop = 1
           ORDER BY d.name
           LIMIT 50`,
        ) as Promise<[DegreeRow[], unknown]>,
      ]);

      // Nothing to enrich — return safe empty state
      if (!topIdRows || topIdRows.length === 0) {
        return {
          streamRows: [] as StreamRow[],
          degreeRows: degreeRows as DegreeRow[],
          cityRows: [] as CityRow[],
        };
      }

      // Inline as integer literals — safe (DB-sourced integers, no user input)
      // and allows MySQL to use idx_cm_profile_fa efficiently.
      const idList = topIdRows.map((r) => r.id).join(",");

      // ── Step 2: stream FA counts + raw city IDs in parallel ──────────────
      //
      // CITIES — why no DISTINCT / ORDER BY here:
      //   MySQL's tmpdir can run out of disk space (Errcode 28) which causes
      //   any query that writes a sort/dedup temp file to fail.  With 1 528
      //   top-university rows the DISTINCT + ORDER BY on city names would
      //   trigger a temp-file write.
      //   Fix: pull raw registeredAddressCityId values (no DISTINCT, no ORDER
      //   BY) using a fast indexed scan, then deduplicate and sort in JS.
      //   The PK-based city name lookup (Step 3) operates on ~200 unique IDs
      //   — tiny, fits in sort_buffer, never writes a temp file.
      //
      // FA COUNTS — COUNT(*) instead of COUNT(DISTINCT):
      //   Avoids the deduplication hash table; still gives correct relative
      //   ordering for the stream filter sidebar.
      const [[faCountRows], [rawCityIdRows]] = await Promise.all([
        pool.query(
          `SELECT
             cm.functionalarea_id,
             COUNT(*) AS college_count
           FROM collegemaster cm
           WHERE cm.collegeprofile_id IN (${idList})
             AND cm.functionalarea_id IS NOT NULL
           GROUP BY cm.functionalarea_id
           ORDER BY college_count DESC
           LIMIT 25`,
        ) as Promise<
          [{ functionalarea_id: number; college_count: number }[], unknown]
        >,

        // Raw scan — no DISTINCT, no ORDER BY, no temp file.
        pool.query(
          `SELECT registeredAddressCityId
           FROM collegeprofile
           WHERE isTopUniversity = 1
             AND registeredAddressCityId IS NOT NULL
           LIMIT 5000`,
        ) as Promise<[{ registeredAddressCityId: number }[], unknown]>,
      ]);

      // Deduplicate city IDs in JS (tiny array, essentially free)
      const uniqueCityIds = [
        ...new Set(rawCityIdRows.map((r) => r.registeredAddressCityId)),
      ];

      if (!faCountRows || faCountRows.length === 0) {
        return {
          streamRows: [] as StreamRow[],
          degreeRows: degreeRows as DegreeRow[],
          cityRows: [] as CityRow[],
        };
      }

      // ── Step 3: resolve FA names + city names in parallel ────────────────
      // Both operate on small ID lists (~25 FA IDs, ~200 city IDs) so MySQL
      // can satisfy them with PK/index lookups — no temp files needed.
      const faIds = faCountRows.map((r) => r.functionalarea_id).join(",");
      const cityIdList = uniqueCityIds.slice(0, 300).join(",");

      const [[faNameRows], [cityRows]] = await Promise.all([
        pool.query(
          `SELECT id, name, pageslug
           FROM functionalarea
           WHERE id IN (${faIds})
             AND name IS NOT NULL
             AND name != ''`,
        ) as Promise<[StreamRow[], unknown]>,

        cityIdList.length > 0
          ? (pool.query(
              `SELECT id, name
               FROM city
               WHERE id IN (${cityIdList})
                 AND name IS NOT NULL
                 AND name != ''
               ORDER BY name
               LIMIT 100`,
            ) as Promise<[CityRow[], unknown]>)
          : Promise.resolve([[] as CityRow[], undefined] as [
              CityRow[],
              unknown,
            ]),
      ]);

      // Merge counts into name rows and sort descending by count
      const countMap = new Map(
        faCountRows.map((r) => [r.functionalarea_id, r.college_count]),
      );
      const streamRows = (faNameRows as StreamRow[])
        .map((f) => ({ ...f, college_count: countMap.get(f.id) ?? 0 }))
        .sort((a, b) => b.college_count - a.college_count);

      return {
        streamRows,
        degreeRows: degreeRows as DegreeRow[],
        cityRows: cityRows as CityRow[],
      };
    } catch (err) {
      console.error("[top-university] getFilterData error:", err);
      // Re-throw
      throw err;
    }
  };

// ─── Core fetch — two-step query ─────────────────────────────────────────────
//
// WHY two steps instead of one big query:
//
//   One query that JOINs collegemaster + GROUP_CONCAT + GROUP BY for ALL
//   1 528 top universities before LIMIT is applied causes MySQL to build a
//   huge temporary table. The two-step approach avoids that:
//
//   Step 1  ID-only query (no GROUP BY, no GROUP_CONCAT, no JOINs to wide
//           tables). MySQL satisfies this with the composite index
//           idx_cp_isTopUniv_rank_rating (isTopUniversity, topUniversityRank,
//           rating) and applies LIMIT 12 before touching any other table.
//
//   Step 2  Enrich exactly the 12 page IDs — GROUP_CONCAT + MIN/MAX over
//           12 rows is near-instant regardless of total table size.
//
//   Count:  Pure COUNT(*) with the same WHERE — no JOINs at all.
//
// SORT FIX — CASE WHEN replaced with boolean expressions:
//   The old  CASE WHEN col IS NULL OR col = 0 THEN 1 ELSE 0 END  prevented
//   MySQL from using the index columns for ORDER BY.
//   Replacing it with  (col IS NULL OR col = 0)  emits the same 0/1 result
//   but is lighter to parse and plays better with the query planner when the
//   index covers (isTopUniversity, topUniversityRank, rating).
// ─────────────────────────────────────────────────────────────────────────────

async function fetchTopUniversities(opts: {
  stream: string;
  degree: string;
  cityId: string;
  stateId: string;
  feesMax: string;
  sort: string;
  page: number;
  limit: number;
}): Promise<{ colleges: CollegeResult[]; total: number; totalPages: number }> {
  const { stream, degree, cityId, stateId, feesMax, sort, page, limit } = opts;
  const offset = (page - 1) * limit;

  // ── Build filter conditions ───────────────────────────────────────────────
  // All optional filters use correlated EXISTS so the ID query never needs to
  // JOIN wide tables like collegemaster or functionalarea.
  const filterConditions: string[] = ["cp.isTopUniversity = 1"];
  const filterParams: (string | number)[] = [];

  if (stream) {
    filterConditions.push(`EXISTS (
      SELECT 1 FROM collegemaster cm2
      INNER JOIN functionalarea fa2 ON fa2.id = cm2.functionalarea_id
      WHERE cm2.collegeprofile_id = cp.id AND fa2.pageslug = ?
    )`);
    filterParams.push(stream);
  }

  if (degree) {
    filterConditions.push(`EXISTS (
      SELECT 1 FROM collegemaster cm3
      INNER JOIN degree d2 ON d2.id = cm3.degree_id
      WHERE cm3.collegeprofile_id = cp.id AND d2.pageslug = ?
    )`);
    filterParams.push(degree);
  }

  if (feesMax && !isNaN(parseInt(feesMax))) {
    filterConditions.push(`EXISTS (
      SELECT 1 FROM collegemaster cm4
      WHERE cm4.collegeprofile_id = cp.id
        AND cm4.fees > 0 AND cm4.fees <= ?
    )`);
    filterParams.push(parseInt(feesMax));
  }

  if (cityId && !isNaN(parseInt(cityId))) {
    filterConditions.push("cp.registeredAddressCityId = ?");
    filterParams.push(parseInt(cityId));
  }

  if (stateId && !isNaN(parseInt(stateId))) {
    filterConditions.push(`EXISTS (
      SELECT 1 FROM city c2
      WHERE c2.id = cp.registeredAddressCityId AND c2.state_id = ?
    )`);
    filterParams.push(parseInt(stateId));
  }

  const filterWhere = filterConditions.join(" AND ");

  console.log('[fetchTopUniversities] Start ID query with opts:', { stream, sort, page, limit });

  // ── Step 1: ID-only query ─────────────────────────────────────────────────
  let idSql: string;

  if (sort === "fees") {
    // Lightweight GROUP BY only when fees sort is requested.
    idSql = `
      SELECT cp.id
      FROM collegeprofile cp
      LEFT JOIN collegemaster cm_s
        ON cm_s.collegeprofile_id = cp.id AND cm_s.fees > 0
      WHERE ${filterWhere}
      GROUP BY cp.id
      ORDER BY MIN(cm_s.fees) ASC, cp.topUniversityRank ASC
      LIMIT ${limit} OFFSET ${offset}
    `;
  } else if (sort === "rating") {
    idSql = `
      SELECT cp.id
      FROM collegeprofile cp
      WHERE ${filterWhere}
      ORDER BY cp.rating DESC, cp.totalRatingUser DESC
      LIMIT ${limit} OFFSET ${offset}
    `;
  } else if (sort === "newest") {
    idSql = `
      SELECT cp.id
      FROM collegeprofile cp
      WHERE ${filterWhere}
      ORDER BY cp.created_at DESC
      LIMIT ${limit} OFFSET ${offset}
    `;
  } else {
    // Default: rank order — universities without a rank (NULL or 0) go last.
    // Using boolean expression (col IS NULL OR col = 0) instead of CASE WHEN
    // so MySQL's query planner can reason about it alongside the composite
    // index idx_cp_isTopUniv_rank_rating.
    idSql = `
      SELECT cp.id
      FROM collegeprofile cp
      WHERE ${filterWhere}
      ORDER BY
        (cp.topUniversityRank IS NULL OR cp.topUniversityRank = 0) ASC,
        cp.topUniversityRank ASC,
        cp.rating DESC
      LIMIT ${limit} OFFSET ${offset}
    `;
  }

  // ── Count query ───────────────────────────────────────────────────────────
  const countSql = `
    SELECT COUNT(*) AS total
    FROM collegeprofile cp
    WHERE ${filterWhere}
  `;

  try {
    // Run ID fetch + count in parallel — both are lightweight.
    console.log('[fetchTopUniversities] Executing pool.query for IDs and Count...');
    const [[idRows], [countRows]] = await Promise.all([
      pool.query(idSql, filterParams) as Promise<[IdRow[], unknown]>,
      pool.query(countSql, filterParams) as Promise<[CountRow[], unknown]>,
    ]);
    console.log('[fetchTopUniversities] ID query Done. Found:', idRows.length);

    const total = countRows[0]?.total ?? 0;

    if (idRows.length === 0) {
      return { colleges: [], total, totalPages: Math.ceil(total / limit) };
    }

    // ── Step 2: Enrich exactly the page IDs ──────────────────────────────
    // GROUP_CONCAT + MIN/MAX over 12 rows is effectively free.
    // IDs come from the DB (integers) — safe to inline.
    const ids = idRows.map((r) => r.id);
    const idList = ids.join(",");

    const enrichSql = `
      SELECT
        cp.id,
        cp.slug,
        COALESCE(
          NULLIF(TRIM(u.firstname), ''),
          NULLIF(TRIM(cp.slug), ''),
          'University'
        )                                                  AS name,
        COALESCE(cp.registeredSortAddress, '')             AS location,
        c.name                                             AS city_name,
        c.state_id,
        cp.bannerimage                                     AS image,
        COALESCE(cp.rating, 0)                             AS rating,
        COALESCE(cp.totalRatingUser, 0)                    AS totalRatingUser,
        cp.ranking,
        cp.isTopUniversity,
        cp.topUniversityRank,
        cp.universityType,
        cp.estyear,
        cp.verified,
        cp.totalStudent,
        GROUP_CONCAT(DISTINCT fa.name ORDER BY fa.name SEPARATOR '|') AS streams_raw,
        MIN(CASE WHEN cm.fees > 0 THEN cm.fees END)        AS min_fees,
        MAX(CASE WHEN cm.fees > 0 THEN cm.fees END)        AS max_fees
      FROM collegeprofile cp
      LEFT JOIN users u           ON u.id  = cp.users_id
      LEFT JOIN city c            ON c.id  = cp.registeredAddressCityId
      LEFT JOIN collegemaster cm  ON cm.collegeprofile_id = cp.id
      LEFT JOIN functionalarea fa ON fa.id = cm.functionalarea_id
      WHERE cp.id IN (${idList})
      GROUP BY
        cp.id, cp.slug, u.firstname, cp.registeredSortAddress,
        c.name, c.state_id, cp.bannerimage, cp.rating, cp.totalRatingUser,
        cp.ranking, cp.isTopUniversity, cp.topUniversityRank, cp.universityType,
        cp.estyear, cp.verified, cp.totalStudent
      ORDER BY FIELD(cp.id, ${idList})
    `;

    console.log('[fetchTopUniversities] Executing Enrich query...');
    const [dataRows] = (await pool.query(enrichSql)) as [CollegeRow[], unknown];
    console.log('[fetchTopUniversities] Enrich query Done.');

    return {
      colleges: buildColleges(dataRows),
      total,
      totalPages: Math.ceil(total / limit),
    };
  } catch (err) {
    console.error("[top-university/page.tsx fetchTopUniversities]", err);
    // Re-throw so unstable_cache does NOT cache this failure.
    // A cached empty result would persist for 5 minutes even after DB recovery.
    throw err;
  }
}

// ─── Direct DB fetch ──────────────────────────────────────────────────────────
// Next.js serialises the opts object. We use direct fetching here since DB index is fast.

// ─── Page ─────────────────────────────────────────────────────────────────────

interface PageProps {
  searchParams: Promise<Record<string, string | string[] | undefined>>;
}

export const metadata: Metadata = {
  title: "Top Universities in India 2025 | AdmissionX",
  description:
    "Discover India's top-ranked universities. Compare by rank, rating, fees, and available streams. Find your perfect university on AdmissionX.",
};

export default async function TopUniversityPage({ searchParams }: PageProps) {
  console.log('[top-university] Page Render Start - Awaiting searchParams...');
  const sp = await searchParams;
  console.log('[top-university] searchParams resolved:', sp);

  const getString = (key: string, fallback = "") =>
    typeof sp[key] === "string" ? (sp[key] as string) : fallback;

  const stream = getString("stream");
  const degree = getString("degree");
  const cityId = getString("city_id");
  const stateId = getString("state_id");
  const feesMax = getString("fees_max");
  const sort = getString("sort", "ranking");
  const page = Math.max(1, parseInt(getString("page", "1")));
  const limit = 12;

  // Both fetches run in parallel.
  // getFilterData is already cached for 10 min; getCachedTopUniversities for 5 min.
  // Errors are caught here (not inside the cached functions) so unstable_cache
  // never stores a failure state — the next request always retries the DB.
  let colleges: CollegeResult[] = [];
  let total = 0;
  let totalPages = 0;
  let streamRows: StreamRow[] = [];
  let degreeRows: DegreeRow[] = [];
  let cityRows: CityRow[] = [];

  try {
    console.log('[top-university] Starting DB Promises...');
    const [universityData, filterData] = await Promise.all([
      fetchTopUniversities({
        stream,
        degree,
        cityId,
        stateId,
        feesMax,
        sort,
        page,
        limit,
      }),
      getFilterData(),
    ]);
    console.log('[top-university] DB Promises Resolved.');
    colleges = universityData.colleges;
    total = universityData.total;
    totalPages = universityData.totalPages;
    streamRows = filterData.streamRows;
    degreeRows = filterData.degreeRows;
    cityRows = filterData.cityRows;
  } catch (err) {
    console.error("[top-university] page data fetch failed:", err);
    // colleges/total/totalPages remain at their safe zero-defaults above.
    // The page renders with an empty state rather than crashing.
  }

  const streamOptions: FilterOption[] = streamRows.map((r) => ({
    id: r.id,
    name: r.name,
    slug: r.pageslug ?? r.name.toLowerCase().replace(/\s+/g, "-"),
    count: r.college_count,
  }));

  const degreeOptions: FilterOption[] = degreeRows.map((r) => ({
    id: r.id,
    name: r.name,
    slug: r.pageslug ?? r.name.toLowerCase().replace(/\s+/g, "-"),
  }));

  const cityOptions: FilterOption[] = cityRows.map((r) => ({
    id: r.id,
    name: r.name,
  }));

  let pageSubtitle = `${total.toLocaleString()} ranked universities across India`;
  if (stream) {
    const streamName =
      streamOptions.find((s) => s.slug === stream)?.name ?? stream;
    pageSubtitle = `${total.toLocaleString()} top ${streamName} universities`;
  }

  return (
    <Suspense
      fallback={
        <div className="min-h-screen bg-neutral-50 flex items-center justify-center">
          <div className="flex flex-col items-center gap-4">
            <div className="w-12 h-12 border-4 border-neutral-200 border-t-red-600 rounded-full animate-spin" />
            <p className="text-sm text-neutral-500 font-medium">Loading universities&hellip;</p>
          </div>
        </div>
      }
    >
      <SearchClient
        initialColleges={colleges}
        initialTotal={total}
        initialTotalPages={totalPages}
        streams={streamOptions}
        degrees={degreeOptions}
        cities={cityOptions}
        initQ=""
        initStream={stream}
        initDegree={degree}
        initCityId={cityId}
        initStateId={stateId}
        initFeesMax={feesMax}
        initSort={sort}
        initPage={page}
        initType="university"
        pageTitle="Top Universities in India"
        pageSubtitle={pageSubtitle}
      />
    </Suspense>
  );
}
